# ghostway — invisible MTProxy stack
# Copy to .env and fill in your values before first launch

DOMAIN=your.domain.com

# Public host shown in proxy links (usually same as DOMAIN)
PUBLIC_HOST=your.domain.com

# Generate with: openssl rand -hex 16
PROXY_SECRET=

XRAY_SERVER_IP=
XRAY_SERVER_PORT=443
XRAY_UUID=
XRAY_SNI=
XRAY_PUBLIC_KEY=
XRAY_SHORT_ID=

# static — serve site/index.html
# proxy  — reverse-proxy to MASK_PROXY_TARGET
MASK_MODE=static
MASK_PROXY_TARGET=https://example.com
