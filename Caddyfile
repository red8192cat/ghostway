# ghostway — Caddyfile
# Caddy runs on port 8443 inside Docker — never exposed to the internet directly.
# telemt owns :443 and TCP-splices non-MTProxy traffic here.
# Port 80 is exposed for ACME HTTP-01 Let's Encrypt challenge and renewal.

{$DOMAIN} {
	# Caddy automatically handles ACME HTTP-01 on port 80
	# and serves HTTPS on port 8443 (remapped via Docker ports config below)
	bind 0.0.0.0

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		-Server
	}

	log {
		output discard
	}

	import /etc/caddy/mask.caddy
}
